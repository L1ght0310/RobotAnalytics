{
  "openapi": "3.0.1",
  "info": {
    "title": "RobotAnalytics.Api",
    "version": "1.0"
  },
  "paths": {
    "/api/Robot/movej": {
      "post": {
        "tags": [
          "Robot"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MoveJCommand"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/MoveJCommand"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/MoveJCommand"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/WeatherForecast": {
      "get": {
        "tags": [
          "WeatherForecast"
        ],
        "operationId": "GetWeatherForecast",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WeatherForecast"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WeatherForecast"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WeatherForecast"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "MoveJCommand": {
        "required": [
          "acceleration",
          "jointAngles",
          "velocity"
        ],
        "type": "object",
        "properties": {
          "jointAngles": {
            "maxItems": 6,
            "minItems": 6,
            "type": "array",
            "items": {
              "type": "number",
              "format": "double"
            },
            "nullable": true
          },
          "velocity": {
            "maximum": 10,
            "minimum": 0,
            "type": "number",
            "format": "double"
          },
          "acceleration": {
            "maximum": 10,
            "minimum": 0,
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "WeatherForecast": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "temperatureC": {
            "type": "integer",
            "format": "int32"
          },
          "temperatureF": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "summary": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}